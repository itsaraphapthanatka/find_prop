# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจาก Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ── ฟีเจอร์ AI (ฝั่งเซิร์ฟเวอร์เท่านั้น — ตั้งใน Vercel > Settings > Environment Variables) ──
# ตัวแปรพวกนี้ "ห้าม" ขึ้นต้นด้วย VITE_ เพราะจะหลุดไปอยู่ใน bundle ฝั่ง client
# AI_API_KEY จำเป็นต้องตั้ง ส่วน URL/MODEL มีค่า default ในโค้ดแล้ว ตั้งเมื่อต้องการ override
AI_API_KEY=YOUR-LLM-API-KEY
# AI_API_URL=https://consoletoken.aunjai.org/api/v1/chat/completions
# AI_MODEL=gemma-4-12b
